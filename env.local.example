# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Note: Use the Service Role Key for background processes like the cron job to write data
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key

# Cron Endpoint Security
CRON_SECRET=super-secret-cron-token-change-me

# Configurable RSS Feeds (comma-separated list of feeds)
RSS_FEEDS=https://search.cnbc.com/rs/search/combinedfeed.cxml,https://www.reutersagency.com/feed/?taxonomy=keywords&term=geopolitics
